// --- 2.1 thsBasicData 异常校验 ---

@testing:case = "test_thsBasicData_arg_count_less", syntaxError=1
iFinD::thsBasicData(accToken, "600519.SH")

@testing:case = "test_thsBasicData_arg_count_more", syntaxError=1
iFinD::thsBasicData(accToken, "600519.SH", "ind", "", "extra")

@testing:case = "test_thsBasicData_token_type", exception=1
iFinD::thsBasicData(12345, "600519.SH", "ths_roe_stock")

@testing:case = "test_thsBasicData_token_form", exception=1
iFinD::thsBasicData(["tk1"], "600519.SH", "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_type", exception=1
iFinD::thsBasicData(accToken, 600519, "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_form", exception=1
iFinD::thsBasicData(accToken, matrix(INT, 2, 2), "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_null", exception=1
iFinD::thsBasicData(accToken, NULL, "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_empty_vec", exception=1
iFinD::thsBasicData(accToken, array(STRING, 0), "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_vec_with_null", exception=1
iFinD::thsBasicData(accToken, ["600519.SH", NULL, ""], "ths_roe_stock")

@testing:case = "test_thsBasicData_indicators_type", exception=1
iFinD::thsBasicData(accToken, "600519.SH", 2024.12.31)

@testing:case = "test_thsBasicData_indicators_empty", exception=1
iFinD::thsBasicData(accToken, "600519.SH", "")

@testing:case = "test_thsBasicData_indipara_type", exception=1
iFinD::thsBasicData(accToken, "600519.SH", "ths_roe_stock", 100)


// --- 2.2 thsDateSequence 异常校验 ---

@testing:case = "test_thsDateSequence_arg_count_less", syntaxError=1
iFinD::thsDateSequence(accToken, "600519.SH", "ind", "", "")

@testing:case = "test_thsDateSequence_arg_count_more", syntaxError=1
iFinD::thsDateSequence(accToken, "600519.SH", "ind", "", "", 2026.01.01, 2026.02.01, "extra")

@testing:case = "test_thsDateSequence_token_type", exception=1
iFinD::thsDateSequence(2026.01.01, "600519.SH", "ths_pe_ttm_stock", "", "", 2026.01.01, 2026.02.01)

@testing:case = "test_thsDateSequence_codes_type", exception=1
iFinD::thsDateSequence(accToken, table(1..3 as id), "ths_pe_ttm_stock", "", "", 2026.01.01, 2026.02.01)

@testing:case = "test_thsDateSequence_indicators_type", exception=1
iFinD::thsDateSequence(accToken, "600519.SH", 123.456, "", "", 2026.01.01, 2026.02.01)

@testing:case = "test_thsDateSequence_indipara_vector", exception=1
iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", ["p1", "p2"], "", 2026.01.01, 2026.02.01)

@testing:case = "test_thsDateSequence_functionpara_matrix", exception=1
iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", matrix(STRING, 2, 2), 2026.01.01, 2026.02.01)

@testing:case = "test_thsDateSequence_startdate_string_type", exception=1
// startDate 必须是 DATE 类型，传 STRING 会报错
iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "", "2026-01-01", 2026.02.01)

@testing:case = "test_thsDateSequence_enddate_string_type", exception=1
// endDate 必须是 DATE 类型，传 STRING 会报错
iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "", 2026.01.01, "2026-02-01")

@testing:case = "test_thsDateSequence_startdate_null", exception=1
// startDate 传入 NULL (DATE) 会报错
iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "", date(NULL), 2026.02.01)

@testing:case = "test_thsDateSequence_logic_reversal", exception=1
// startDate 晚于 endDate 会报错
iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "", 2026.03.01, 2026.01.01)



// --- 2.3 thsHistoryQuotes 异常校验 ---

@testing:case = "test_thsHistoryQuotes_arg_count_less", syntaxError=1
iFinD::thsHistoryQuotes(accToken, "600519.SH", "ind", "")

@testing:case = "test_thsHistoryQuotes_arg_count_more", syntaxError=1
