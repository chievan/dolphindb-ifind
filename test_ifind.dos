assert 3, res5_1.rows() == 2   // 两个标的各一行

// --- 1.6 并发执行测试 (Concurrency Tests) ---
@testing:case = "test_Concurrent_thsBasicData"
print("\n=== 并发测试 thsBasicData ===")
def concurrentBasicData(tk, codes, ind) {
    total = 0
    for (i in 1..3) {
        res = iFinD::thsBasicData(tk, codes, ind)
        if (res.rows() > 0) total += 1
        sleep(500)
    }
    return total
}
jobs_bd = array(STRING, 0)
for (i in 1..2) {
    jobId = "iFinD_bd_job_" + string(i)
    submitJob(jobId, "iFinD Parallel BasicData", concurrentBasicData, accToken, "600519.SH", "ths_stock_short_name_stock")
    jobs_bd.append!(jobId)
}
for (jid in jobs_bd) { res = getJobReturn(jid, true); assert 601, res == 3 }

@testing:case = "test_Concurrent_thsDateSequence"
print("\n=== 并发测试 thsDateSequence ===")
def concurrentDateSequence(tk, codes, ind, start, end) {
    total = 0
    for (i in 1..3) {
        res = iFinD::thsDateSequence(tk, codes, ind, "", "", start, end)
        if (res.rows() > 0) total += 1
        sleep(500)
    }
    return total
}
jobs_ds = array(STRING, 0)
for (i in 1..2) {
    jobId = "iFinD_ds_job_" + string(i)
    submitJob(jobId, "iFinD Parallel DateSequence", concurrentDateSequence, accToken, "600519.SH", "ths_pe_ttm_stock", 2024.12.25, 2025.01.05)
    jobs_ds.append!(jobId)
}
for (jid in jobs_ds) { res = getJobReturn(jid, true); assert 602, res == 3 }

@testing:case = "test_Concurrent_thsHistoryQuotes"
print("\n=== 并发测试 thsHistoryQuotes ===")
def concurrentHistoryQuotes(tk, codes, ind, start, end) {
    total = 0
    for (i in 1..3) {
        res = iFinD::thsHistoryQuotes(tk, codes, ind, "", start, end)
        if (res.rows() > 0) total += 1
        sleep(500)
    }
    return total
}
jobs_hq = array(STRING, 0)
for (i in 1..2) {
    jobId = "iFinD_hq_job_" + string(i)
    submitJob(jobId, "iFinD Parallel HistoryQuotes", concurrentHistoryQuotes, accToken, "600519.SH", "open,high,low,close", 2024.01.01, 2024.01.10)
    jobs_hq.append!(jobId)
}
for (jid in jobs_hq) { res = getJobReturn(jid, true); assert 603, res == 3 }

@testing:case = "test_Concurrent_thsHighFrequency"
print("\n=== 并发测试 thsHighFrequency ===")
def concurrentHighFrequency(tk, codes, ind, start, end) {
    total = 0
    for (i in 1..3) {
        res = iFinD::thsHighFrequency(tk, codes, ind, "Interval:5", start, end)
        if (res.rows() > 0) total += 1
        sleep(500)
    }
    return total
}
jobs_hf = array(STRING, 0)
for (i in 1..2) {
    jobId = "iFinD_hf_job_" + string(i)
    submitJob(jobId, "iFinD Parallel HighFrequency", concurrentHighFrequency, accToken, "600519.SH", "close,volume", 2025.12.30T09:30:00, 2026.01.05T10:00:00)
    jobs_hf.append!(jobId)
}
for (jid in jobs_hf) { res = getJobReturn(jid, true); assert 604, res == 3 }

@testing:case = "test_Concurrent_thsRealTime"
print("\n=== 并发测试 thsRealTime ===")
def concurrentRealTime(tk, codes, ind) {
    total = 0
    for (i in 1..3) {
        res = iFinD::thsRealTime(tk, codes, ind)
        if (res.rows() > 0) total += 1
        sleep(500)
    }
    return total
}
jobs_rt = array(STRING, 0)
for (i in 1..2) {
    jobId = "iFinD_rt_job_" + string(i)
    submitJob(jobId, "iFinD Parallel RealTime", concurrentRealTime, accToken, "600519.SH", "latest")
    jobs_rt.append!(jobId)
}
for (jid in jobs_rt) { res = getJobReturn(jid, true); assert 605, res == 3 }

