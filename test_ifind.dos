@testing:case = "test_thsHistoryQuotes_date_string_type", exception=1
// startDate 必须是 DATE 类型，传 STRING 格式会报错
iFinD::thsHistoryQuotes(accToken, "600519.SH", "close", "", "2026-01-01", 2026.02.01)


// --- 2.4 thsHighFrequency 异常校验 ---

@testing:case = "test_thsHighFrequency_arg_count_less", syntaxError=1
iFinD::thsHighFrequency(accToken, "600519.SH", "ind", "")

@testing:case = "test_thsHighFrequency_arg_count_more", syntaxError=1
iFinD::thsHighFrequency(accToken, "600519.SH", "ind", "", "", "", "extra")

@testing:case = "test_thsHighFrequency_starttime_missing_sec", exception=1
// thsHighFrequency 要求必须包含秒。如果模块未在 DDB 侧拦截，API 也会报错
iFinD::thsHighFrequency(accToken, "600519.SH", "open", "", "2026-03-11 09:30", "2026-03-11 15:00:00")

@testing:case = "test_thsHighFrequency_codes_matrix", exception=1
iFinD::thsHighFrequency(accToken, matrix(STRING, 1, 1), "open", "", "2026-03-11 09:30:00", "2026-03-11 15:00:00")

@testing:case = "test_thsHighFrequency_indicators_empty_vec", exception=1
iFinD::thsHighFrequency(accToken, "600519.SH", array(STRING, 0), "", "2026-03-11 09:30:00", "2026-03-11 15:00:00")


// --- 2.5 thsRealTime 异常校验 ---

@testing:case = "test_thsRealTime_arg_count_less", syntaxError=1
iFinD::thsRealTime(accToken, "600519.SH")

@testing:case = "test_thsRealTime_arg_count_more", syntaxError=1
iFinD::thsRealTime(accToken, "600519.SH", "ind", "extra")

@testing:case = "test_thsRealTime_token_type", exception=1
iFinD::thsRealTime(1234.56, "600519.SH", "latest")

@testing:case = "test_thsRealTime_codes_null_scalar", exception=1
iFinD::thsRealTime(accToken, string(NULL), "latest")

@testing:case = "test_thsRealTime_indicators_form", exception=1
iFinD::thsRealTime(accToken, "600519.SH", ["latest", "amount"])

// --- 2.6 getAccessToken 异常校验 ---

@testing:case = "test_getAccessToken_arg_count_less", exception=1
iFinD::getAccessToken()

@testing:case = "test_getAccessToken_arg_count_more", syntaxError=1
iFinD::getAccessToken(refreshToken, "extra")

@testing:case = "test_getAccessToken_type", exception=1
iFinD::getAccessToken(12345)

@testing:case = "test_getAccessToken_null", exception=1
iFinD::getAccessToken(NULL)

@testing:case = "test_getAccessToken_empty", exception=1
iFinD::getAccessToken("")

@testing:case = "test_getAccessToken_too_short", exception=1
// 触发长度 < 100 的启发式逻辑拦截
iFinD::getAccessToken("eyJ_too_short_token")

@testing:case = "test_getAccessToken_invalid_content", exception=1
// 长度足够但内容是胡乱构造的 Base64，预期触发 API 401 报错
fake_long_token = take("a", 150).concat("")
iFinD::getAccessToken(fake_long_token)

// ====================================================
// 第三部分：功能反向测试 (Reverse Functional Tests)
// ====================================================

// --- 3.1 thsBasicData 内容反向 ---

@testing:case = "test_thsBasicData_invalid_codes", exception=1
// 格式正确(String)，但代码不存在
iFinD::thsBasicData(accToken, "999999.ZZ", "ths_stock_short_name_stock")

@testing:case = "test_thsBasicData_invalid_indicators", exception=1
// 格式正确，但指标名错误
iFinD::thsBasicData(accToken, "600519.SH", "ths_wrong_indicator_abc")

// 格式正确，但参数 Key 或内容无效，能返回空值
@testing:case = "test_thsBasicData_invalid_indipara"
res_basic_invalid_indipara = iFinD::thsBasicData(accToken, "600519.SH", "ths_roe_stock", "invalid_key:value")
assert 701, isNull(res_basic_invalid_indipara.ths_roe_stock) or res_basic_invalid_indipara.rows() >= 0
if(!isNull(res_basic_invalid_indipara.ths_roe_stock) and res_basic_invalid_indipara.rows() > 0){
    cols = res_basic_invalid_indipara.values()
    nullAll = true
    for(i in 1:(size(cols)-1)){
        v = cols[i]
        nullAll = nullAll and sum(isNull(v)) == size(v)
    }
    assert 702, nullAll
}


// --- 3.2 thsDateSequence 内容反向 ---

@testing:case = "test_thsDateSequence_invalid_interval"
// Interval 取值非法 (应为 D/W/M/Q/S/Y)
re = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Interval:Z", 2024.01.01, 2024.02.01)
assert 1, re.size() > 0

@testing:case = "test_thsDateSequence_future_date"
// 查询未来日期的数据，thsDateSequence 默认返回最后一天数据
re = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "", 2030.01.01, 2030.01.10)
assert 1, re.size() > 0


// --- 3.3 thsHistoryQuotes 内容反向 ---

@testing:case = "test_thsHistoryQuotes_invalid_cps"
// 复权方式 (CPS) 为无效数字，选填参数不影响结果，返回默认结果
re = iFinD::thsHistoryQuotes(accToken, "600519.SH", "close", "CPS:99", 2024.01.01, 2024.02.01)
assert 1, re.size() > 0

@testing:case = "test_thsHistoryQuotes_not_listed_date", exception=1
// 查询股票没有数据的区间日期，会报错
iFinD::thsHistoryQuotes(accToken, "600519.SH", "close", "", 1990.01.01, 1990.01.10)


// --- 3.4 thsHighFrequency 内容反向 ---
@testing:case = "test_thsHighFrequency_invalid_codes", exception=1
// 代码不存在
iFinD::thsHighFrequency(accToken, "INVALID.TICKER", "open", "Interval:1", 2024.03.11T09:30:00, 2024.03.11T15:00:00)

@testing:case = "test_thsHighFrequency_invalid_frequency", exception=1
// 不支持的分钟频率 (如 17 分钟)
iFinD::thsHighFrequency(accToken, "600519.SH", "open", "Interval:17", 2024.03.11T09:30:00, 2024.03.11T15:00:00)

@testing:case = "test_thsHighFrequency_invalid_indicators", exception=1
// 指标名错误
iFinD::thsHighFrequency(accToken, "600519.SH", "open_close", "Interval:1", 2024.03.11T09:30:00, 2024.03.11T15:00:00)

@testing:case = "test_thsHighFrequency_time_reversal", exception=1
// startTime 晚于 endTime 会报错
iFinD::thsHighFrequency(accToken, "600519.SH", "open", "Interval:1", 2024.03.11T21:30:00, 2024.03.11T15:00:00)

@testing:case = "test_thsHighFrequency_weekend_query", exception=1
// 在非交易日(周末)查询高频数据
iFinD::thsHighFrequency(accToken, "600519.SH", "open", "", 2026.03.15T09:30:00, 2026.03.15T15:00:00)


// --- 3.5 thsRealTime 内容反向 ---
@testing:case = "test_thsRealTime_invalid_token", exception=1
// token瞎输入，会直接报错
iFinD::thsRealTime("INVALID.TOKEN", "600519.SH", "latest")

@testing:case = "test_thsRealTime_invalid_codes", exception=1
// 格式正确，但代码不存在，会直接报错
iFinD::thsRealTime(accToken, "INVALID.TICKER", "latest")

@testing:case = "test_thsRealTime_mixed_codes"
// 混合了正确和明显错误的代码 (取决于 API 是部分返回还是整体报错),部分返回
res_rt_mixed_codes = iFinD::thsRealTime(accToken, "600519.SH,INVALID.TICKER", "latest")
assert 703, !isNull(res_rt_mixed_codes.values())
assert 704, res_rt_mixed_codes.rows() >= 1
assert 705, any(res_rt_mixed_codes.thscode == "600519.SH")

@testing:case = "test_thsRealTime_error_ind"
// 混合了正确和明显错误的指标 (取决于 API 是部分返回还是整体报错)，部分返回
res_rt_error_ind = iFinD::thsRealTime(accToken, "600519.SH", "close,hh_cc")
assert 706, !isNull(res_rt_error_ind.values())
assert 707, res_rt_error_ind.rows() >= 1
assert 708, any(res_rt_error_ind.thscode == "600519.SH")

@testing:case = "test_thsRealTime_invalid_indicators", exception=1
// 输入明显的错误指标，会直接报错
iFinD::thsRealTime(accToken, "600519.SH", "hh_cc")

// ====================================================
// 第四部分：依赖校验 (Dependency Validation)
// ====================================================

@testing:case = "test_MissingHttpClientPlugin"
// 模拟 httpClient 插件未加载的情况
ok_missing_plugin = true
try {
    loadPlugin("httpClient"); 
    go
 
} catch(x) { 
    print("Module load failed: " + x) 
}
assert 709, ok_missing_plugin == true

