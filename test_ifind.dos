use DolphinDBModules::easyTLDataImport::tbSchema::dfsSchema::tradeSchema
try { loadPlugin("httpClient") } catch(ex) {}
use iFinD

// 1. 设置长效刷新凭证 (请确保此处为最新的有效 Token)
refreshToken = "eyJ_YOUR_TOKEN"
// 2. 获取 AccessToken 并复用
accToken = iFinD::getAccessToken(refreshToken)
print("AccessToken 获取成功: " + accToken + "...")

@testing:case = "test_module_info"
print("\n=== 测试 module_info (模块信息) ===")
info = getLoadedModules()
assert 0, "iFinD" in info.moduleName
print("module_info 验证通过")

// ====================================================
// 第一部分：功能测试 (Functional Tests)
// ====================================================

// --- 1.1 thsBasicData (基础快照数据) ---
print("\n=== 测试 thsBasicData (基础数据) ===")
@testing:case = "test_thsBasicData_singleCode"
// token 类型: 分别使用 accessToken 和 refreshToken
res1_1_acc = iFinD::thsBasicData(accToken, "600519.SH", "ths_stock_short_name_stock")
assert 1 ,res1_1_acc[`ths_stock_short_name_stock][0] == "贵州茅台"
res1_1_ref = iFinD::thsBasicData(refreshToken, "600519.SH", "ths_stock_short_name_stock")
assert 2 ,res1_1_ref[`ths_stock_short_name_stock][0] == "贵州茅台"
// codes 多标的输入
@testing:case = "test_thsBasicData_multiCodes"
res1_2_codes = iFinD::thsBasicData(accToken, "000001.SZ,600030.SH", "ths_stock_short_name_stock")
assert 1 ,res1_2_codes[`ths_stock_short_name_stock][0] == "平安银行"
assert 2 ,res1_2_codes[`ths_stock_short_name_stock][1] == "中信证券"
//多指标 + 指标参数 (分号分隔不同指标的参数)
@testing:case = "test_thsBasicData_Rich"
res1_3 = iFinD::thsBasicData(accToken, "000001.SZ,600030.SH", "ths_stock_short_name_stock,ths_roe_stock", ";2023-12-31")
assert 1, eqObj(res1_3.columnNames() , ["thscode","ths_stock_short_name_stock","ths_roe_stock"])==true
assert 2, res1_3.count() == 2
res1_4 = iFinD::thsBasicData(accToken, "000001.SZ,600030.SH", "ths_stock_short_name_stock,ths_roe_stock,ths_roe_avg_by_ths_stock", ";2022-12-31;2023-12-31")
assert 3, eqObj(res1_4.columnNames() , ["thscode","ths_stock_short_name_stock","ths_roe_stock","ths_roe_avg_by_ths_stock"])==true
assert 4, res1_4.count() == 2
//大写指标自动转小写 (模块内部调用 lower() 纠正)
res1_5 = iFinD::thsBasicData(accToken, "000001.SZ,600030.SH", "ths_stock_short_name_stock,ths_roe_STOCK", ";2023-12-31")
assert 5, eqObj(res1_5.columnNames() , ["thscode","ths_stock_short_name_stock","ths_roe_stock"])==true
assert 6, res1_5.count() == 2
//indicatorPara 日期格式兼容: YYYY-MM-DD 与 YYYYMMDD
res1_6 = iFinD::thsBasicData(accToken, "000001.SZ,600030.SH", "ths_stock_short_name_stock,ths_roe_STOCK", ";20231231")
assert 7, res1_6.count() == 2

//indicatorPara 日期格式兼容: YYYY-MM-DD 与 YYYYMMDD
res1_7 = iFinD::thsBasicData(accToken, "000001.SZ,600030.SH", "ths_stock_short_name_stock,ths_roe_STOCK", ";2023-12-31")
assert 8, res1_7.count() == 2


// --- 1.2 thsDateSequence (日期序列数据) ---
print("\n=== 测试 thsDateSequence (日期序列) ===")
@testing:case = "test_thsDateSequence_Rich"
//codes 多标的输入
res2_0 = iFinD::thsDateSequence(accToken, "000001.SZ,600030.SH", "ths_pe_ttm_stock", "", "Interval:D", 2024.12.25, 2025.01.05)
assert 1 ,res2_0.count() == 14
assert 2 ,res2_0.columnNames() == ["thscode","time","ths_pe_ttm_stock"]
//不同 Interval 周期 (D/W/M/Q/Y)，跨年跨月跨节假日
res2_1 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Interval:D", 2024.12.25, 2025.01.05)
assert 3 ,res2_1.count() == 7
res2_2 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Interval:W", 2024.11.25, 2025.01.05)
assert 4 ,res2_2.count() == 6
res2_3 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Interval:M", 2024.10.25, 2025.01.05)
assert 5 ,res2_3.count() == 3

res2_4 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Interval:Q", 2024.08.25, 2025.01.05)
assert 6 ,res2_4.count() == 2
res2_5 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Interval:Y", 2023.12.25, 2025.01.05)
assert 7 ,res2_5.count() == 2
// Days 日历日参数
res2_6 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Days:Alldays", 2024.12.25, 2025.01.05)
assert 8 ,res2_6.count() == 12
res2_7 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "Days:Tradedays", 2024.12.25, 2025.01.05)
assert 9 ,res2_7.count() == 7
//Fill参数
res2_8 = iFinD::thsDateSequence(accToken, "000001.SZ,600000.SH", "ths_close_price_stock,ths_pe_ttm_stock", ",100,;", "Fill:Previous", 2022.06.05, 2022.07.05)
res2_9 = iFinD::thsDateSequence(accToken, "000001.SZ,600000.SH", "ths_close_price_stock,ths_pe_ttm_stock", ",100,;", "Fill:Blank", 2022.06.05, 2022.07.05)
//indicatorPara 日期格式兼容: YYYY-MM-DD 与 YYYYMMDD（indiPara 参数仍是 STRING，不受影响）
res2_11 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_total_shares_stock", "2022-07-05", "", 2024.12.25, 2025.01.05)
res2_12 = iFinD::thsDateSequence(accToken, "600519.SH", "ths_total_shares_stock", "20220705", "", 2024.12.25, 2025.01.05)
//多指标 + 指标参数覆盖
res2_13 = iFinD::thsDateSequence(accToken, "000002.SZ", "ths_pe_ttm_stock,ths_pb_latest_stock", "", "Interval:W", 2024.01.01, 2024.03.01)
res2_14 = iFinD::thsDateSequence(accToken, "30033.SZ,600030.SH", "ths_total_equity_atoopc_stock,ths_regular_report_actual_dd_stock", ",100;", "Interval:D", 2024.01.01, 2024.03.01)

// --- 1.3 thsHistoryQuotes (历史 K 线行情) ---
@testing:case = "test_thsHistoryQuotes_Rich"
print("\n=== 测试 thsHistoryQuotes (历史行情) ===")
expectedCols3 = ["thscode", "time", "open", "high", "low", "close", "volume"]
//正常日行情，跨周、跨月、跨年
res3_0 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "Interval:D", 2024.12.01, 2025.01.10)
assert 1, res3_0.rows() > 0
assert 2, eqObj(res3_0.columnNames(), expectedCols3) == true
//不同复权方式 CPS (1-不复权, 2-前复权, 3-后复权)
res3_1 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "CPS:1,Interval:D", 2024.01.01, 2024.01.10)
assert 3, res3_1.rows() > 0
assert 4, eqObj(res3_1.columnNames(), expectedCols3) == true
res3_2 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "CPS:2,Interval:D", 2024.01.01, 2024.01.10)
assert 5, res3_2.rows() > 0
assert 6, eqObj(res3_2.columnNames(), expectedCols3) == true
res3_3 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "CPS:3,Interval:D", 2024.01.01, 2024.01.10)
assert 7, res3_3.rows() > 0
assert 8, eqObj(res3_3.columnNames(), expectedCols3) == true
//不同 Fill 参数 (Previous-沿用前值, Blank-留空)
res3_4 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "Fill:Previous", 2024.01.01, 2024.01.10)
assert 9, res3_4.rows() > 0
assert 10, eqObj(res3_4.columnNames(), expectedCols3) == true
res3_5 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "Fill:Blank", 2024.01.01, 2024.01.10)
assert 11, res3_5.rows() > 0
assert 12, eqObj(res3_5.columnNames(), expectedCols3) == true
//不同 Currency 货币类型 (GHB-港元, RMB-人民币, MHB-美元)
res3_6 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "Currency:GHB", 2024.01.01, 2024.01.10)
assert 13, res3_6.rows() > 0
assert 14, eqObj(res3_6.columnNames(), expectedCols3) == true
res3_7 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "Currency:RMB", 2024.01.01, 2024.01.10)
assert 15, res3_7.rows() > 0
assert 16, eqObj(res3_7.columnNames(), expectedCols3) == true
res3_8 = iFinD::thsHistoryQuotes(accToken, "600519.SH", "open,high,low,close,volume", "Currency:MHB", 2024.01.01, 2024.01.10)
assert 17, res3_8.rows() > 0
assert 18, eqObj(res3_8.columnNames(), expectedCols3) == true

// --- 1.4 thsHighFrequency (日内高频行情) ---
@testing:case = "test_thsHighFrequency_Rich"
print("\n=== 测试 thsHighFrequency (高频行情) ===")
expectedCols4 = ["thscode", "time", "close", "open", "volume"]
// 分钟频率，跨日、跨周、跨月、跨年
res4_1 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Interval:1", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 1, res4_1.rows() > 0
assert 2, eqObj(res4_1.columnNames(), expectedCols4) == true
// 不同分钟频率 (5/10/15/30/60)
res4_2 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Interval:5", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 3, res4_2.rows() > 0
assert 4, eqObj(res4_2.columnNames(), expectedCols4) == true
res4_3 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Interval:10", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 5, res4_3.rows() > 0
assert 6, eqObj(res4_3.columnNames(), expectedCols4) == true
res4_4 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Interval:15", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 7, res4_4.rows() > 0
assert 8, eqObj(res4_4.columnNames(), expectedCols4) == true
res4_5 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Interval:30", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 9, res4_5.rows() > 0
assert 10, eqObj(res4_5.columnNames(), expectedCols4) == true
res4_6 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Interval:60", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 11, res4_6.rows() > 0
assert 12, eqObj(res4_6.columnNames(), expectedCols4) == true
//不同 Fill 参数 (Previous-沿用前值, Blank-留空)
res4_7 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Fill:Previous", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 13, res4_7.rows() > 0
assert 14, eqObj(res4_7.columnNames(), expectedCols4) == true
res4_8 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Fill:Blank", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 15, res4_8.rows() > 0
assert 16, eqObj(res4_8.columnNames(), expectedCols4) == true
//不同 Timeformat 参数 (BeiJingTime-北京时间, LocalTime-当地时间)
res4_9 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Timeformat:BeiJingTime", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 17, res4_9.rows() > 0
assert 18, eqObj(res4_9.columnNames(), expectedCols4) == true
res4_10 = iFinD::thsHighFrequency(accToken, "600519.SH", "close,open,volume", "Timeformat:LocalTime", 2025.12.25T09:25:00, 2026.01.05T09:35:00)
assert 19, res4_10.rows() > 0
assert 20, eqObj(res4_10.columnNames(), expectedCols4) == true

// --- 1.5 thsRealTime (实时行情快照) ---
@testing:case = "test_thsRealTime_Rich"
print("\n=== 测试 thsRealTime (实时行情) ===")
// 多标的 + 多指标实时快照
expectedCols5 = ["thscode", "latest", "bid1", "ask1"]
res5_1 = iFinD::thsRealTime(accToken, "600519.SH,000001.SZ", "latest,bid1,ask1")
